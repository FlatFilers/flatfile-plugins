{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noImplicitOverride": true,
    "lib": [ "es2015", "dom" ],
    "target": "es2015",
    "moduleResolution": "node",
    "strict": true
  },
  "exclude": [
    "**/node_modules/",
    "**/dist/",
    "**/.*",
    "**/*.spec.ts"
  ]
}
